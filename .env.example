# SailPoint ISC tenant name (the subdomain part of your URL)
# e.g. if your tenant URL is https://acme.identitynow.com, set this to: acme
ISC_TENANT=your-tenant-name

# OAuth 2.0 client credentials (from a Personal Access Token or API client)
# Generate a PAT at: https://[tenant].identitynow.com/ui/d/user-preferences/personal-access-tokens
ISC_CLIENT_ID=your-client-id
ISC_CLIENT_SECRET=your-client-secret

# Base domain for the tenant. Defaults to identitynow.com if not set.
# Set to identitynow-demo.com for demo tenants.
# ISC_DOMAIN=identitynow-demo.com
